{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=uslugi_ryadom.db"
  },
  "Jwt": {
    "Key": "SUPER_SECRET_KEY_AT_LEAST_32_CHARACTERS_LONG",
    "Issuer": "UslugiRyadom",
    "Audience": "UslugiRyadomUsers",
    "ExpiresInMinutes": 60
  },
  "AllowedHosts": "*",
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ],
    "Enrich": [ "FromLogContext" ]
  }
}
